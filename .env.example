VITE_APP_VERSION=soft-launch
# Optional: Zulu Royal Game Analytics ingest endpoint.
# Example: https://YOUR_SUPABASE_REF.supabase.co/functions/v1/game-telemetry-ingest
# You can also pass ?telemetry=https://your-endpoint.example/events in the game URL.
VITE_SUNRISE_TELEMETRY_URL=
# Optional public anti-spoofing signal, not a secret auth guarantee.
# You can also pass ?telemetry_key=... or ?ingest_key=... in the game URL.
VITE_SUNRISE_TELEMETRY_KEY=
